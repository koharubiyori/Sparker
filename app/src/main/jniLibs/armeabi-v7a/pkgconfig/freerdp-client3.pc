prefix=${pcfiledir}/..
exec_prefix=${prefix}
libdir=${prefix}/.
includedir=${prefix}/include/freerdp3/
libs=-lfreerdp-client3

Name: FreeRDP client
Description: FreeRDP: A Remote Desktop Protocol Implementation
URL: http://www.freerdp.com/
Version: 3.12.1
Requires: 
Requires.private:  freerdp3
Libs: -L${libdir} ${libs}
Libs.private: -ldl -lpthread 
Cflags: -I${includedir}
